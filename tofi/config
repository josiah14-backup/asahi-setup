# physical-keybindings defaults to true, meaning tofi matches its own
# internal shortcuts (Escape to close, etc.) against the physical key
# position regardless of the active keyboard layout/remap. Under
# hypr/hyprland.conf's caps:swapescape kb_option, that means the
# physical Caps Lock key still behaves like Caps Lock inside tofi even
# though every other Wayland client correctly sees it as Escape --
# confirmed directly: pressing it in tofi still toggled letter case
# instead of closing the launcher. false makes tofi honor the active
# layout like everything else does.
physical-keybindings=false
